import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args){
        Scanner as=new Scanner(System.in);
     int num=as.nextInt();
        int reverse=0;
        while(num!=0)
        {
            int digit=num%10;
            reverse=reverse*10+digit;
            num=num/10;
        }
        System.out.println(reverse);
    }
}
        
