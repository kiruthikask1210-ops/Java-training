import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
       Scanner as=new Scanner(System.in);
       int n=as.nextInt();
       int sum=0;
       int[] a=new int[n];
        for (int i=0;i<n;i++){
            a[i]=as.nextInt();
        }
        for (int i=0;i<n;i++){
            if(a[i]%2!=0){
                sum=sum+a[i];
            }
            }
            System.out.println(sum);
        }
    }
