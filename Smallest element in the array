import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
       Scanner as=new Scanner(System.in);
        int n=as.nextInt();
        int[]a=new int[n];
        for(int i=0;i<n;i++){
            a[i]=as.nextInt();
        }
        int l=a[0];
        for(int i=1;i<n;i++){
            if(a[i]<l){
                l=a[i];
            }
        }
        System.out.println(+l);
        
    }
}
