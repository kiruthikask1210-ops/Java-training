import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
       Scanner as=new Scanner(System.in);
        int n=as.nextInt();
        int[]a=new int[n];
        int sum=0;
        
        for(int i=0;i<n;i++){
            a[i]=as.nextInt();
        }
        for(int i=0;i<n;i++){
            sum=sum+a[i];
        }
        System.out.println(+sum);
        
    }
}
