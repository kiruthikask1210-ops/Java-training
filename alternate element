import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
       Scanner as=new Scanner(System.in);
       int n=as.nextInt();
       int[] a=new int[n];
        for (int i=0;i<n;i++){
            a[i]=as.nextInt();
        }
        for (int i=0;i<a.length;i+=2){
            System.out.println(a[i]);
        }
    }
}
