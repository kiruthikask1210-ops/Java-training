import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner as=new Scanner(System.in);
        int n=4;
        n=as.nextInt();
        for(int i=1;i<=n;i++)
        {
            for(int j=1;j<=i;j++){
                System.out.print("*");
                
            }
            System.out.println();
        }
    }
}
